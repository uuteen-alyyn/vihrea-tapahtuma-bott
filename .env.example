# Discord
DISCORD_BOT_TOKEN=

# Tapahtumat API base URL (no trailing slash)
API_BASE_URL=https://tapahtumat.vihreaturku.fi

# IMAP — leave blank to disable email channel
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_PORT=993
IMAP_POLL_INTERVAL_SECONDS=60

# SMTP — used for sending confirmation/reply emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Database
# SQLite: DATABASE_URL=sqlite:///audit.db
# MySQL:  DATABASE_URL=mysql+pymysql://user:pass@host/dbname
DATABASE_URL=sqlite:///audit.db

# Rate limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=3600

# Encryption key for API keys stored in database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
